{
  "version": 2,
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/api/v1/payment-intents/:id/confirm", "destination": "/api/v1/[id]?id=:id" },
    { "source": "/api/v1/payment-intents/:id", "destination": "/api/v1/[id]?id=:id" },
    { "source": "/v1/payment-intents/:id/confirm", "destination": "/api/v1/[id]?id=:id" },
    { "source": "/v1/payment-intents/:id", "destination": "/api/v1/[id]?id=:id" },
    { "source": "/api/payment-intents/:id/confirm", "destination": "/api/v1/[id]?id=:id" },
    { "source": "/api/payment-intents/:id", "destination": "/api/v1/[id]?id=:id" },
    { "source": "/api/payment-intents", "destination": "/api/v1/payment-intents" },
    { "source": "/solana-pay/:intentId", "destination": "/api/solana-pay/[intentId]?intentId=:intentId" },
    { "source": "/api/solana-pay/:intentId", "destination": "/api/solana-pay/[intentId]?intentId=:intentId" },
    { "source": "/v1/solana-pay/:intentId", "destination": "/api/solana-pay/[intentId]?intentId=:intentId" },
    { "source": "/v1/webhooks/helius", "destination": "/api/v1/webhooks/helius" },
    { "source": "/api/v1/webhooks/helius", "destination": "/api/v1/webhooks/helius" },
    { "source": "/v1/simulation/parse-qris", "destination": "/api/v1/simulation/parse-qris" },
    { "source": "/v1/simulation/quote", "destination": "/api/v1/simulation/quote" },
    { "source": "/v1/simulation/pay", "destination": "/api/v1/simulation/pay" },
    { "source": "/v1/demo-tx", "destination": "/api/v1/simulation/pay" },
    { "source": "/api/v1/demo-tx", "destination": "/api/v1/simulation/pay" },
    { "source": "/v1/merchants/:nmid", "destination": "/api/v1/merchants?nmid=:nmid" },
    { "source": "/api/v1/merchants/:nmid", "destination": "/api/v1/merchants?nmid=:nmid" },
    { "source": "/v1/merchants", "destination": "/api/v1/merchants" },
    { "source": "/api/v1/merchants", "destination": "/api/v1/merchants" },
    { "source": "/v1/(.*)", "destination": "/api/v1/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app/(.*)", "destination": "/app/$1" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/download/(.*)", "destination": "/download/$1" },
    { "source": "/download", "destination": "/download/index.html" },
    { "source": "/demo/(.*)", "destination": "/demo/$1" },
    { "source": "/demo", "destination": "/demo/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(api|v1)/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, Idempotency-Key" }
      ]
    },
    {
      "source": "/health",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Surrogate-Control", "value": "no-store" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://solq-backend.onrender.com https://solq.railway.app https://api.coingecko.com https://lite-api.jup.ag https://quote-api.jup.ag https://price.jup.ag https://api.jup.ag https://api.binance.com https://mainnet.helius-rpc.com https://api.mainnet-beta.solana.com https://api.devnet.solana.com https://solana-api.projectserum.com https://tokens.jup.ag https://open.er-api.com https://api.frankfurter.app; worker-src blob:; frame-ancestors 'none';" }
      ]
    }
  ]
}
