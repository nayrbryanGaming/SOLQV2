{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "IDRX_API_KEY": "@idrx_api_key",
    "IDRX_SECRET_KEY": "@idrx_secret_key",
    "SOLANA_RPC_URL": "@solana_rpc_url"
  },
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "memory": 512,
      "runtime": "nodejs18.x"
    },
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 512,
      "runtime": "nodejs18.x"
    }
  },
  "redirects": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/v1/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}

