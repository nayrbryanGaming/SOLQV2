<?xml version="1.0" encoding="utf-8"?>
<!--
  Dev-first policy:
  - Allows HTTP during local Android testing (LAN / emulator IPs).
  - HTTPS remains preferred for production endpoints.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
