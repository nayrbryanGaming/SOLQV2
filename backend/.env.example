# ═══════════════════════════════════════════════════════════════════════════════
# SOLQ Backend — Environment Variables (COMPLETE TEMPLATE)
# Copy this file to .env and fill in real values before deployment.
# NEVER commit .env with real secrets to git.
# Reference: SOLQ_COMPLETE_REBUILD_MASTER_PROMPT_v3 §2.4
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Cluster ───────────────────────────────────────────────────────────────────
# 'devnet' for testing, 'mainnet-beta' for production
SOLANA_CLUSTER=mainnet-beta

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Helius is the primary recommended provider (https://helius.dev)
# Format: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
HELIUS_WEBSOCKET_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WEBHOOK_SECRET=your_helius_webhook_secret

# Devnet RPC (for testing)
HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Fallback RPCs (optional — system falls back automatically)
QUICKNODE_RPC_URL=https://your-endpoint.quiknode.pro/YOUR_KEY/
# SOLANA_RPC_URL is legacy fallback; prefer HELIUS_RPC_URL
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jito (priority transactions)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (Supabase, Railway, or self-hosted)
DATABASE_URL=postgresql://solq_user:secure_password@db.example.com:5432/solq_prod?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for BullMQ settlement queue (Upstash recommended for serverless)
REDIS_URL=redis://your-redis.upstash.io:6379

# ── Pricing Oracle ────────────────────────────────────────────────────────────
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
JUPITER_PRICE_URL=https://price.jup.ag/v6/price
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
JUPITER_SWAP_URL=https://quote-api.jup.ag/v6/swap
PRICE_CACHE_TTL_SECONDS=60
PRICE_MAX_STALENESS_SECONDS=300

# ── IDRX Off-Ramp (PRIMARY settlement path) ──────────────────────────────────
# Get credentials from IDRX team (api.idrx.co)
# Signature: HMAC-SHA256(timestamp + METHOD + urlPath + body)
IDRX_API_BASE_URL=https://api.idrx.co
IDRX_API_KEY=your_idrx_api_key_here
IDRX_SECRET_KEY=your_idrx_secret_key_here
IDRX_MINT_ADDRESS=idrxZcP8xiKkYk6XGD4uz1dxEYCWSgKDHqgjsBbwDur

# Devnet output token (USDC substitute for devnet testing)
DEVNET_OUTPUT_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Settlement (Xendit Disbursement API) ──────────────────────────────────────
PJP_PROVIDER=IDRX_DIRECT
XENDIT_API_KEY=xnd_production_...
XENDIT_API_BASE_URL=https://api.xendit.co/v2/disbursements
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_verification_token
SETTLEMENT_NOTIFICATION_EMAIL=settlements@solq.app
FAST_LANE_THRESHOLD_IDR=500000
BATCH_SETTLEMENT_HOUR_UTC=16

# ── SOLQ Wallets ──────────────────────────────────────────────────────────────
SOLQ_FEE_WALLET=ETcQvsQek2w9feLfsqoe4AypCWfnrSwQiv3djqocaP2m
TREASURY_WALLET=ETcQvsQek2w9feLfsqoe4AypCWfnrSwQiv3djqocaP2m
ESCROW_WALLET_PUBLIC_KEY=your_escrow_wallet_public_key
GAS_HOT_WALLET_PUBLIC_KEY=your_gas_hot_wallet_public_key
KMS_KEY_ARN=arn:aws:kms:ap-southeast-1:123456789:key/your-key-id

# ── Fee Config ────────────────────────────────────────────────────────────────
PLATFORM_SPREAD_BPS=50
MIN_FEE_IDR=2500
GAS_HOT_WALLET_MIN_BALANCE_SOL=1.0
DAILY_ESCROW_WITHDRAWAL_LIMIT_USDC=100000

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_here_do_not_use_this_value
CORS_ALLOWED_ORIGINS=https://solq.my.id,https://api.solq.my.id
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PER_MIN=60
DISABLE_RATE_LIMIT=0
CERTIFICATE_HASH=sha256_hash_of_ssl_cert_for_flutter_pinning

# ── GitHub Mirror (HUKUM 8) ───────────────────────────────────────────────────
SOLQV2_MIRROR_TOKEN=ghp_your_github_personal_access_token

# ── Audit & Compliance ────────────────────────────────────────────────────────
# WORM log aggregator URL (optional — Datadog, Logtail, AWS CloudWatch)
AUDIT_WEBHOOK_URL=

# ── Float Pool ────────────────────────────────────────────────────────────────
FLOAT_POOL_IDR=0
