# ═══════════════════════════════════════════════════════════════════════════════
#  SOLQ BACKEND — LOCAL / DEV CONFIGURATION
#  Copy from .env.example and fill real values. NEVER commit real secrets to git.
# ═══════════════════════════════════════════════════════════════════════════════

# SERVER
PORT=3000
NODE_ENV=development

# CLUSTER — 'devnet' for testing, 'mainnet-beta' for production
SOLANA_CLUSTER=devnet

# SOLANA RPC — set HELIUS_RPC_URL for production reliability
HELIUS_RPC_URL=
HELIUS_DEVNET_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# DATABASE
DATABASE_URL=postgresql://solq_user:password@localhost:5432/solq_dev?sslmode=disable

# REDIS (BullMQ requires Redis)
REDIS_URL=redis://localhost:6379

# IDRX — fill with real values from api.idrx.co
IDRX_API_KEY=
IDRX_SECRET_KEY=
IDRX_API_URL=https://api.idrx.co

# XENDIT (optional secondary disbursement)
# XENDIT_API_KEY=xnd_production_...
# XENDIT_WEBHOOK_TOKEN=

# TREASURY
TREASURY_WALLET=ETcQvsQek2w9feLfsqoe4AypCWfnrSwQiv3djqocaP2m

# RATE LIMITING
RATE_LIMIT_PER_MIN=60
DISABLE_RATE_LIMIT=0

# COINGECKO (optional)
# COINGECKO_API_KEY=
