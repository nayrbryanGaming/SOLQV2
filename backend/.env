# ═══════════════════════════════════════════════════════════════════════════════
#  SOLQ BACKEND CONFIGURATION - MAINNET PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════════

# SERVER CONFIG
PORT=3000
NODE_ENV=production

# SOLANA RPC (Mainnet)
# Free tier works but use Helius/Triton for production scale
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# IDRX PARTNER CREDENTIALS (LIVE PRODUCTION)
IDRX_API_KEY=2acefd2554ea82fd
IDRX_SECRET_KEY=098fa029ec1d23c2930fcc3b5e38bb4173ffcc0c4becc45e4cd3bf158a728531
IDRX_API_URL=https://api.idrx.co

# XENDIT PJP (Last-mile disbursement to GoPay/OVO/BCA)
# Get key at: https://dashboard.xendit.co/settings/developers#api-keys
# XENDIT_API_KEY=xnd_production_xxxxxxxxxxxx

# FLOAT POOL (Pre-funded IDR for instant merchant settlement)
# Set this to your initial IDR float balance (integer)
# With float: merchant gets paid in 5-30 sec
# Without float: merchant gets paid in 5-60 min via IDRX redeem
FLOAT_POOL_IDR=0

# COINGECKO API KEY (Optional - for higher rate limits)
# Get free key at: https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=your_key_here

# TREASURY WALLET (Revenue Collection)
TREASURY_WALLET=ETcQvsQek2w9feLfsqoe4AypCWfnrSwQiv3djqocaP2m
