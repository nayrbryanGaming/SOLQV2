# Vercel Environment Variables
# Copy these to Vercel dashboard under Settings → Environment Variables

# IDRX Off-Ramp API
IDRX_API_KEY=your_idrx_api_key_here
IDRX_SECRET_KEY=your_idrx_secret_key_here

# Solana RPC (Using Helius.dev - free tier)
SOLANA_RPC_URL=https://helius-rpc.com/

# Optional: Custom Solana RPC endpoint
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: IDRX API URL
# IDRX_API_URL=https://api.idrx.co

