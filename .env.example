# ═══════════════════════════════════════════════════════════════════════
# SOLQ 2.0 — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════

# ── SOLANA / RPC ──────────────────────────────────────────────────────
# Helius RPC endpoint (mainnet). Get key at https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Solana cluster: mainnet-beta | devnet
SOLANA_CLUSTER=mainnet-beta

# Helius webhook secret (for on-chain confirmation push notifications)
HELIUS_WEBHOOK_SECRET=your_helius_webhook_secret

# ── DATABASE ──────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase recommended)
DATABASE_URL=postgresql://user:password@host:5432/solq_db

# ── CACHE ─────────────────────────────────────────────────────────────
# Redis for settlement queue and price caching
REDIS_URL=redis://localhost:6379

# ── XENDIT (IDR Settlement) ───────────────────────────────────────────
# Production key: xnd_production_... | Test key: xnd_development_...
XENDIT_API_KEY=xnd_production_YOUR_XENDIT_KEY
XENDIT_API_BASE_URL=https://api.xendit.co/v2/disbursements
# Webhook validation token (set in Xendit dashboard)
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token

# ── IDRX (Stablecoin Off-ramp) ────────────────────────────────────────
IDRX_API_KEY=your_idrx_api_key
IDRX_SECRET_KEY=your_idrx_secret_key

# ── WALLET ADDRESSES (PUBLIC — safe to commit, do NOT put private keys) ──
# Treasury/escrow wallet that receives IDRX from Jupiter swaps
GAS_HOT_WALLET_PUBLIC_KEY=YOUR_HOT_WALLET_PUBKEY

# ── SERVER ────────────────────────────────────────────────────────────
PORT=3000
# Comma-separated additional CORS origins (production domains are hardcoded)
CORS_ALLOWED_ORIGINS=

# ── RATE LIMITING ─────────────────────────────────────────────────────
# Requests per minute per IP (default 60). Set to 0 to disable.
RATE_LIMIT_PER_MIN=60
# Set to 1 to disable rate limiting entirely (dev only)
DISABLE_RATE_LIMIT=0

# ── SECURITY / ENCRYPTION ─────────────────────────────────────────────
# AES-256-GCM key for PII field encryption in DB (BUG-061).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be exactly 64 hex chars (32 bytes).
DATABASE_ENCRYPTION_KEY=generate_with_node_crypto_randomBytes_32_hex

# ── ADMIN DASHBOARD ───────────────────────────────────────────────────
ADMIN_DASH_USER=admin
ADMIN_DASH_PASS=change_this_strong_password

# ── MONITORING ────────────────────────────────────────────────────────
# Sentry DSN for error monitoring (optional but strongly recommended)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
